# Local dev: copy to .env.local
# CI deploy: set in GitHub → Settings → Secrets and variables → Actions
#   Secret:  VITE_WEB3FORMS_ACCESS_KEY
#   Variables: VITE_CALENDLY_URL, VITE_BASE_PATH (optional), VITE_TRAINING_VIDEO_URL (optional)

VITE_WEB3FORMS_ACCESS_KEY=your_access_key_here
VITE_CALENDLY_URL=https://calendly.com/your-username/consultation
# GitHub project Pages only — e.g. /archicastel/ (omit or use / for user/org root site)
# VITE_BASE_PATH=/archicastel/
# Optional: only for a small self-hosted MP4 (not for large Google Drive files)
# VITE_TRAINING_VIDEO_URL=/videos/training/intro.mp4
